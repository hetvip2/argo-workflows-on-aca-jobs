{
  "name": "argo-workflows-on-aca-jobs-helper",
  "version": "0.1.0",
  "private": true,
  "description": "Azure Container Apps Jobs helper for an existing Argo Workflows control plane.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/cli.js",
